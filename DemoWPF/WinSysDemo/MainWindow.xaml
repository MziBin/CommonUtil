<Window x:Class="WinSysDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinSysDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="程序使用内存：" HorizontalAlignment="Left" Margin="267,116,0,0" VerticalAlignment="Top" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="394,120,0,0" TextWrapping="Wrap" Text="0" x:Name="appMemory"  VerticalAlignment="Top" Width="120" RenderTransformOrigin="1.142,0.798" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="394,162,0,0" TextWrapping="Wrap" Text="0" x:Name="freeMemory" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="394,208,0,0" TextWrapping="Wrap" Text="0" x:Name="totalMemory" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <TextBox HorizontalAlignment="Left" Margin="394,259,0,0" TextWrapping="Wrap" Text="0" x:Name="CpuUsage" VerticalAlignment="Top" Width="120" FontSize="16"/>
        <Label Content="CPU使用率：" HorizontalAlignment="Left" Margin="288,255,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Label Content="总内存：" HorizontalAlignment="Left" Margin="315,204,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Label Content="可用内存："  HorizontalAlignment="Left" Margin="299,158,0,0" VerticalAlignment="Top" FontSize="16"/>

    </Grid>
</Window>
